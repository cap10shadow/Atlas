root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.java]
indent_style = tab
indent_size = 4

[*.gradle]
indent_style = tab
indent_size = 4

[{*.yml,*.yaml}]
indent_style = space
indent_size = 2

[*.{ts,tsx,js,jsx,mjs,cjs,json,css}]
indent_style = space
indent_size = 2

[*.{sh,bash}]
indent_style = tab
indent_size = 4
end_of_line = lf

[*.md]
trim_trailing_whitespace = false

[*.bat]
end_of_line = crlf

[Makefile]
indent_style = tab
